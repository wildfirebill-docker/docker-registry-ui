{
  "registries": [
    {
      "name": "Local Registry",
      "url": "http://localhost:5001",
      "auth": {
        "type": "none"
      }
    },
    {
      "name": "Production Registry",
      "url": "https://registry.example.com",
      "auth": {
        "type": "basic",
        "username": "admin",
        "password": "secret"
      }
    },
    {
      "name": "Private Registry with Token",
      "url": "https://registry-private.example.com",
      "auth": {
        "type": "bearer",
        "token": "your-bearer-token-here"
      }
    }
  ]
}
